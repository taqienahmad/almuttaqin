DATABASE_URL=postgresql+asyncpg://sekolah:sekolah@localhost:5432/sekolah
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# Email notifications via plain SMTP (free with e.g. a Gmail app password,
# or any free-tier transactional email provider). Leave SMTP_HOST empty to
# disable sending (notifications are just logged instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=sekolah@example.com
SMTP_FROM_NAME=Website Sekolah

